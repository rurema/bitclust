#!/usr/bin/env ruby
# frozen_string_literal: true

# RRD → Markdown バッチ変換スクリプト
#
# Usage:
#   ruby bin/rrd2md <input_dir> <output_dir>
#   ruby bin/rrd2md --graph ../doctree/refm/api/src ../doctree/manual/api
#
# Options:
#   --dry-run    変換せず対象ファイルのリストのみ表示
#   --verbose    各ファイルの変換状況を表示
#   --file FILE  単一ファイルのみ変換（出力は標準出力）
#   --graph      input_dir の LIBRARIES から #@include グラフを解析し、
#                新パイプライン形の Markdown ツリーへ変換する
#                （MarkdownOrchestrator: front matter 注入・grouping include 除去・
#                  全体版ゲート解除・LIBRARIES 自体はスキップ）
#   --scope LO,HI  --graph の対象版範囲 [LO, HI)（デフォルト 3.0,4.2。
#                  旧版サルベージ時は別範囲を指定して再実行できる）
#   --doc        散文ページ（refm/doc）モード: DocConverter で正規化つき変換
#                （例: ruby bin/rrd2md --doc ../doctree/refm/doc ../doctree/manual/doc）
#   --capi       C API リファレンス（refm/capi/src）モード: CapiConverter で変換
#                （例: ruby bin/rrd2md --capi ../doctree/refm/capi/src ../doctree/manual/capi）

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)
require 'bitclust/rrd_to_markdown'
require 'bitclust/markdown_orchestrator'
require 'bitclust/doc_converter'
require 'bitclust/capi_converter'

class RRD2MDConverter
  def initialize(argv)
    @dry_run = argv.delete('--dry-run')
    @verbose = argv.delete('--verbose')
    @graph = argv.delete('--graph')
    @doc = argv.delete('--doc')
    @capi = argv.delete('--capi')
    @scope = (extract_option(argv, '--scope') || '3.0,4.2').split(',')
    @single_file = extract_option(argv, '--file')

    if @single_file
      @input_dir = nil
      @output_dir = nil
    elsif argv.size == 2
      @input_dir = argv[0]
      @output_dir = argv[1]
    else
      usage
    end
  end

  def run
    if @single_file
      convert_single_file(@single_file)
    else
      convert_directory
    end
  end

  private

  def extract_option(argv, name)
    idx = argv.index(name)
    return nil unless idx
    argv.delete_at(idx)
    argv.delete_at(idx)
  end

  def usage
    warn "Usage: #{$0} <input_dir> <output_dir>"
    warn "       #{$0} --file <file>"
    warn ""
    warn "Options:"
    warn "  --dry-run    Show target files without converting"
    warn "  --verbose    Show each file being converted"
    warn "  --file FILE  Convert a single file (output to stdout)"
    exit 1
  end

  def convert_single_file(path)
    rrd = File.read(path, encoding: 'UTF-8')
    puts BitClust::RRDToMarkdown.convert(rrd)
  end

  def convert_directory
    files = @doc ? BitClust::DocConverter.files(@input_dir) : collect_files(@input_dir)
    orchestrator = nil
    if @graph
      orchestrator = BitClust::MarkdownOrchestrator.new(@input_dir,
        scope: BitClust::IncludeGraph::Scope.new(*@scope))
      orchestrator.warnings.each { |w| warn "  W: #{w}" }
      files = files.select { |f| orchestrator.convert?(f) }
    end

    if @dry_run
      files.each { |f| puts f }
      warn "#{files.size} files would be converted"
      return
    end

    converted = 0
    errors = []
    emitted = []

    files.each do |rel_path|
      input_path = File.join(@input_dir, rel_path)

      begin
        rrd = File.read(input_path, encoding: 'UTF-8')
        outputs =
          if orchestrator
            orchestrator.units(rel_path, rrd)
              .map { |u| [u.path, orchestrator.convert_unit(u)] }
          elsif @doc
            [[to_md_path(rel_path), BitClust::DocConverter.convert(rrd)]]
          elsif @capi
            [[to_md_path(rel_path), BitClust::CapiConverter.convert(rrd)]]
          else
            [[to_md_path(rel_path), BitClust::RRDToMarkdown.convert(rrd)]]
          end

        outputs.each do |out_rel, md|
          output_path = File.join(@output_dir, out_rel)
          FileUtils.mkdir_p(File.dirname(output_path))
          File.write(output_path, md, encoding: 'UTF-8')
          emitted << out_rel
          warn "  #{rel_path} -> #{out_rel}" if @verbose
        end

        converted += 1
      rescue => e
        errors << [rel_path, e]
        warn "  ERROR: #{rel_path}: #{e.message}" if @verbose
      end
    end

    warn "Converted: #{converted}/#{files.size} files"
    unless errors.empty?
      warn "Errors: #{errors.size}"
      errors.each { |path, e| warn "  #{path}: #{e.message}" }
    end

    # 大文字小文字のみが異なる出力名は macOS/Windows の case-insensitive FS で
    # チェックアウト不能になるため、バッチ全体で検証して失敗させる
    # （途中のディレクトリ名も見る。解消は orchestrator の .lib 回避か
    # ソース側のリネームで行う）
    collisions = emitted.flat_map { |p|
      parts = p.split('/')
      (1..parts.size).map { |n| parts.first(n).join('/') }
    }.uniq.group_by(&:downcase).each_value.select { |names| names.size > 1 }
    unless collisions.empty?
      collisions.each { |names| warn "  CASE COLLISION: #{names.sort.join(', ')}" }
      abort "case-insensitive filename collisions: #{collisions.size}"
    end
  end

  def collect_files(dir)
    files = []
    Dir.glob("#{dir}/**/*", File::FNM_DOTMATCH).sort.each do |path|
      next unless File.file?(path)
      next if File.basename(path).start_with?('.')
      rel = path.sub("#{dir}/", '')
      files << rel
    end
    files
  end

  def to_md_path(rel_path)
    if rel_path.end_with?('.rd')
      rel_path.sub(/\.rd\z/, '.md')
    else
      "#{rel_path}.md"
    end
  end
end

require 'fileutils'
RRD2MDConverter.new(ARGV.dup).run
